# ================================================
# 生产部署环境变量（服务器上复制为 .env 后再填值）
# ================================================

# MySQL root 密码；至少 16 位随机
# MYSQL_ROOT_PASSWORD=Zk89CHK8zyMkXyjj

# 数据库名，保持默认即可
MYSQL_DATABASE=run_app

# JWT 签名密钥；至少 32 位随机（例如 openssl rand -hex 32）
# JWT_SECRET=luMrnsmB4WriZShiNKblEjcTVdTJkk5P

# ================================================
# 听歌识曲：ACRCloud（可选，不填就只走本地 BPM 检测）
# ------------------------------------------------
# 申请入口：https://console.acrcloud.com/
# 创建一个 "Music Recognition" 项目拿到下面三个值；host 形如
#   identify-eu-west-1.acrcloud.com / identify-cn-north-1.acrcloud.com
# 三个都留空时，/api/run/analyze-and-recommend 会自动降级为只用
# music-tempo 做 BPM 检测（不影响整体流程，只是拿不到"识别到了哪首歌"）
# ================================================
ACRCLOUD_HOST=
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
