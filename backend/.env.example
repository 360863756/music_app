# ================================================
# 生产部署环境变量（服务器上复制为 .env 后再填值）
# ================================================

# MySQL root 密码；至少 16 位随机
# MYSQL_ROOT_PASSWORD=Zk89CHK8zyMkXyjj

# 数据库名，保持默认即可
MYSQL_DATABASE=run_app

# JWT 签名密钥；至少 32 位随机（例如 openssl rand -hex 32）
# JWT_SECRET=luMrnsmB4WriZShiNKblEjcTVdTJkk5P

# ================================================
# 听歌识曲：ACRCloud（可选，不填就只走本地 BPM 检测）
# ------------------------------------------------
# 申请入口：https://console.acrcloud.com/
# 创建一个 "Music Recognition" 项目拿到下面三个值；host 形如
#   identify-eu-west-1.acrcloud.com / identify-cn-north-1.acrcloud.com
# 三个都留空时，/api/run/analyze-and-recommend 会自动降级为只用
# music-tempo 做 BPM 检测（不影响整体流程，只是拿不到"识别到了哪首歌"）
# ================================================
ACRCLOUD_HOST=
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=

# ================================================
# 短信验证码：用于注册 / 登录 / 找回密码 / 绑定手机
# ------------------------------------------------
# SMS_PROVIDER 可选值：
#   - mock    ：默认。只在后端日志里打印验证码，不真发短信。本地/开发环境用这个。
#   - aliyun  ：阿里云短信服务（见下方配置）
#
# 切换到 aliyun 后，缺任何一个必填项都会让服务**启动失败**——这是有意设计，
# 防止生产环境环境变量配错，结果短信看似发出去其实根本没发。
# ================================================
SMS_PROVIDER=mock

# ----- 阿里云短信（SMS_PROVIDER=aliyun 时才需要填）-----
# 控制台：https://dysms.console.aliyun.com/
#
# 申请步骤：
#   1) 资质管理：上传营业执照（个体户也可），等通过（一般 1 个工作日）
#   2) 国内消息 → 签名管理 → 申请「行境」签名（验证码用途），1-3 工作日审核
#   3) 国内消息 → 模板管理 → 申请验证码模板，每个场景一条；变量名必须为 ${code}
#        模板示例（最终以阿里云审核通过的为准）：
#          【行境】您的注册验证码 ${code}，5 分钟内有效。请勿向他人泄露。
#          【行境】您的登录验证码 ${code}，5 分钟内有效。请勿向他人泄露。
#          【行境】您的找回密码验证码 ${code}，5 分钟内有效。如非本人操作请忽略。
#          【行境】您的手机绑定验证码 ${code}，5 分钟内有效。请勿向他人泄露。
#   4) RAM 控制台 → 创建子账号 → 仅授权「AliyunDysmsFullAccess」→ 拿子账号的 AK/SK
#      （**绝对不要在这里填阿里云主账号的 AK，泄露=全资源被盗**）
#
# 模板兜底规则：四个 scene 模板缺哪个就回落到 ALIYUN_SMS_TEMPLATE_DEFAULT，
# 所以最简模式是只配一个 DEFAULT 模板（先跑起来），后续再分场景拆开提审。
ALIYUN_SMS_AK=
ALIYUN_SMS_SK=
ALIYUN_SMS_SIGN_NAME=

# 各场景模板 CODE（从阿里云控制台「模板管理」复制，形如 SMS_xxxxxxx）
# 留空则回落到 ALIYUN_SMS_TEMPLATE_DEFAULT
ALIYUN_SMS_TEMPLATE_REGISTER=
ALIYUN_SMS_TEMPLATE_LOGIN=
ALIYUN_SMS_TEMPLATE_RESET=
ALIYUN_SMS_TEMPLATE_BIND=
ALIYUN_SMS_TEMPLATE_DEFAULT=

# 可选；只有走专有网络/金融云时才需要改，公网部署留空即可
ALIYUN_SMS_ENDPOINT=
